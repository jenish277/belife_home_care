            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Products</th>
                            <th>Discount</th>
                            <th>Payment</th>
                            <th>Pending</th>
                            <th>Total</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="ordersTableBody">
                        <% orders.forEach(order=> { %>
                            <tr
                                class="<%= (order.paymentMethod === 'Pending' || order.pending > 0) ? 'table-warning' : '' %>">
                                <td><strong>
                                        <%= order.user.name %>
                                    </strong></td>
                                <td>
                                    <% order.products.forEach(item=> { %>
                                        <div><span class="badge bg-primary">
                                                <%= item.product.name %>
                                            </span> <strong>Qty: <%= item.quantity %></strong></div>
                                        <% }) %>
                                </td>
                                <td>₹<%= order.discount || 0 %>
                                </td>
                                <td><span
                                        class="badge <%= order.paymentMethod === 'GPay' ? 'bg-success' : order.paymentMethod === 'Pending' ? 'bg-warning' : 'bg-secondary' %>">
                                        <%= order.paymentMethod || 'Cash' %>
                                    </span></td>
                                <td><strong style="color: #ef4444;">₹<%= (order.paymentMethod==='Pending' ? order.total
                                            : 0) + (order.pending || 0) %></strong></td>
                                <td><strong>₹<%= order.total %></strong></td>
                                <td>
                                    <%= order.orderDate.toDateString() %>
                                </td>
                                <td>
                                    <button class="btn btn-warning btn-sm edit-order-btn" data-id="<%= order._id %>"
                                        data-name="<%= order.user.name %>" data-phone="<%= order.user.phoneNumber %>"
                                        data-address="<%= order.user.address %>"
                                        data-products='<%= JSON.stringify(order.products.map(p => ({productId: p.product._id, quantity: p.quantity}))) %>'
                                        data-discount="<%= order.discount || 0 %>"
                                        data-payment="<%= order.paymentMethod || 'Cash' %>"
                                        data-pending="<%= order.pending || 0 %>">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <form action="/admin/orders/delete/<%= order._id %>" method="POST"
                                        style="display:inline;" onsubmit="return confirmDelete(this)">
                                        <button type="submit" class="btn btn-danger btn-sm"><i
                                                class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
