        function updateAvailableProducts(modalId) {
            const modal = document.getElementById(modalId);
            if (!modal) return;
            
            const selects = Array.from(modal.querySelectorAll('.product-select'));
            const selectedValues = selects.map(s => s.value).filter(v => v);
            
            selects.forEach(select => {
                const options = select.querySelectorAll('option');
                options.forEach(option => {
                    if (option.value === "") return;
                    if (selectedValues.includes(option.value) && select.value !== option.value) {
                        option.disabled = true;
                    } else {
                        option.disabled = false;
                    }
                });
            });
        }

        function attachProductEventListeners(row) {
            const productSelect = row.querySelector('.product-select');
            const quantityInput = row.querySelector('.quantity-input');
            const removeBtn = row.querySelector('.remove-product');

            const isEdit = row.closest('#editModal') !== null;
            const contextId = isEdit ? 'editModal' : 'addModal';

            if (productSelect) {
                productSelect.addEventListener('change', () => {
                    calculateTotal();
                    updateAvailableProducts(contextId);
                });
            }
            if (quantityInput) quantityInput.addEventListener('input', calculateTotal);
            if (removeBtn) {
                removeBtn.addEventListener('click', function () {
                    row.remove();
                    calculateTotal();
                    updateRemoveButtons(contextId);
                    updateAvailableProducts(contextId);
                });
            }
            
            if (contextId) {
                updateAvailableProducts(contextId);
            }
        }

        function updateRemoveButtons(contextId) {
            if (!contextId) {
                updateRemoveButtons('addModal');
                updateRemoveButtons('editModal');
                return;
            }
            const modal = document.getElementById(contextId);
            if (!modal) return;
            const rows = modal.querySelectorAll('.product-row');
            rows.forEach((row) => {
                const removeBtn = row.querySelector('.remove-product');
                if (removeBtn) {
                    removeBtn.style.display = rows.length > 1 ? 'block' : 'none';
                }
            });
        }

        // Calculate total for order forms
        function calculateTotal() {
            calculateModalTotal('addModal', 'discount', 'subtotal', 'discountAmount', 'totalAmount');
            calculateModalTotal('editModal', 'editDiscount', null, null, null);
        }

        function calculateModalTotal(modalId, discountId, subtotalId, discountAmountId, totalAmountId) {
            const modal = document.getElementById(modalId);
            if (!modal) return;

            let subtotal = 0;
            let hasError = false;

            modal.querySelectorAll('.product-row').forEach(row => {
                const select = row.querySelector('.product-select');
                const qtyInput = row.querySelector('.quantity-input');

                if (select && select.value && qtyInput && qtyInput.value) {
                    const price = parseFloat(select.options[select.selectedIndex].dataset.price) || 0;
                    const quantity = parseInt(qtyInput.value) || 0;

                    // The format is "Product Name - ₹Price (Stock: X)"
                    const optionText = select.options[select.selectedIndex].text;
                    const productName = optionText.split(' - ')[0];
                    const stockMatch = optionText.match(/Stock:\s*(\d+)/i);
                    const availableStock = stockMatch ? parseInt(stockMatch[1]) : 0;

                    // Check stock availability
                    if (quantity > availableStock) {
                        if (qtyInput) {
                            qtyInput.style.borderColor = '#ef4444';
                            qtyInput.style.backgroundColor = '#fee2e2';
                        }

                        // Show custom error modal
                        const stockErrorTitle = document.getElementById('stockErrorTitle');
                        const stockErrorMessage = document.getElementById('stockErrorMessage');
                        if (stockErrorTitle) stockErrorTitle.textContent = productName;
                        if (stockErrorMessage) {
                            stockErrorMessage.innerHTML = `
                                <strong>Available Stock:</strong> ${availableStock} units<br>
                                <strong>Requested:</strong> ${quantity} units<br><br>
                                <span style="color: #ef4444;">Please reduce the quantity to ${availableStock} or less.</span>
                            `;
                        }

                        // Use Bootstrap Modal smartly
                        const stockModalEl = document.getElementById('stockErrorModal');
                        if (stockModalEl) {
                            const errorModal = bootstrap.Modal.getInstance(stockModalEl) || new bootstrap.Modal(stockModalEl);
                            errorModal.show();
                        }

                        if (qtyInput) qtyInput.value = availableStock;
                        hasError = true;
                    } else {
                        if (qtyInput) {
                            qtyInput.style.borderColor = '#e2e8f0';
                            qtyInput.style.backgroundColor = 'white';
                        }
                    }

                    subtotal += price * parseInt(qtyInput.value);
                }
            });

            const discountInput = document.getElementById(discountId);
            const discount = parseFloat(discountInput?.value || 0);

            if (subtotalId) {
                const subtotalSpan = document.getElementById(subtotalId);
                const discountSpan = document.getElementById(discountAmountId);
                const totalSpan = document.getElementById(totalAmountId);

                const total = subtotal - discount;

                if (subtotalSpan) subtotalSpan.textContent = subtotal.toFixed(2);
                if (discountSpan) discountSpan.textContent = discount.toFixed(2);
                if (totalSpan) totalSpan.textContent = total.toFixed(2);
            }
        }

        // Initialize product event listeners
        document.addEventListener('DOMContentLoaded', function () {
            // Attach event listeners to initial product row
            const initialProductRow = document.querySelector('.product-row');
            if (initialProductRow) {
                attachProductEventListeners(initialProductRow);
            }

            // Attach event listeners to discount input
            const discountInput = document.getElementById('discount');
            if (discountInput) {
                discountInput.addEventListener('input', calculateTotal);
            }
        });

        // Excel Export functionality
        function showDateModal() {
            // Set today's date as default end date
            const today = new Date().toISOString().split('T')[0];
            const endDate = document.getElementById('endDate');
            if (endDate) endDate.value = today;

            // Set 30 days ago as default start date
            const thirtyDaysAgo = new Date();
            thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
            const startDate = document.getElementById('startDate');
            if (startDate) startDate.value = thirtyDaysAgo.toISOString().split('T')[0];

            new bootstrap.Modal(document.getElementById('dateModal')).show();
        }

        function setQuickDate(range) {
            const today = new Date();
            const startDate = new Date();

            switch (range) {
                case 'today':
                    startDate.setTime(today.getTime());
                    break;
                case 'week':
                    startDate.setDate(today.getDate() - 7);
                    break;
                case 'month':
                    startDate.setMonth(today.getMonth() - 1);
                    break;
                case 'year':
                    startDate.setFullYear(today.getFullYear() - 1);
                    break;
            }

            const startDateEl = document.getElementById('startDate');
            const endDateEl = document.getElementById('endDate');
            if (startDateEl) startDateEl.value = startDate.toISOString().split('T')[0];
            if (endDateEl) endDateEl.value = today.toISOString().split('T')[0];
        }

        function exportToExcel() {
            const startDateEl = document.getElementById('startDate');
            const endDateEl = document.getElementById('endDate');

            const startDate = new Date(startDateEl?.value);
            const endDate = new Date(endDateEl?.value);

            if (!startDate || !endDate || isNaN(startDate.getTime()) || isNaN(endDate.getTime())) {
                alert('Please select both start and end dates');
                return;
            }

            if (startDate > endDate) {
                alert('Start date must be before end date');
                return;
            }

            const orders = ordersData.filter(order => {
                const orderDate = new Date(order.orderDate);
                return orderDate >= startDate && orderDate <= endDate;
            });

            if (orders.length === 0) {
                alert('No orders found in the selected date range');
                return;
            }

            // Show loading state
            const exportBtn = event.target;
            const originalText = exportBtn.innerHTML;
            exportBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Exporting...';
            exportBtn.disabled = true;

            setTimeout(() => {
                // Create worksheet data
                const wsData = [
                    ['Customer Name', 'Phone', 'Address', 'Products', 'Discount', 'Payment Method', 'Pending', 'Total', 'Date']
                ];

                orders.forEach(order => {
                    const products = order.products.map(p => `${p.product.name}(${p.quantity})`).join('; ');
                    const pending = (order.paymentMethod === 'Pending' ? order.total : 0) + (order.pending || 0);

                    wsData.push([
                        order.user.name || '',
                        order.user.phoneNumber || '',
                        order.user.address || '',
                        products,
                        order.discount || 0,
                        order.paymentMethod || 'Cash',
                        pending,
                        order.total,
                        new Date(order.orderDate).toLocaleDateString('en-IN')
                    ]);
                });

                // Create workbook and worksheet
                const ws = XLSX.utils.aoa_to_sheet(wsData);
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, 'Orders');

                // Generate filename with date range
                const startStr = startDate.toLocaleDateString('en-IN').replace(/\//g, '-');
                const endStr = endDate.toLocaleDateString('en-IN').replace(/\//g, '-');
                const filename = `orders_${startStr}_to_${endStr}.xlsx`;

                // Download file
                XLSX.writeFile(wb, filename);

                // Reset button and close modal
                exportBtn.innerHTML = originalText;
                exportBtn.disabled = false;
                bootstrap.Modal.getInstance(document.getElementById('dateModal')).hide();

                // Show success message
                showSuccessMessage(`Successfully exported ${orders.length} orders to Excel!`);
            }, 500);
        }

        function showSuccessMessage(message) {
            const toast = document.createElement('div');
            toast.className = 'position-fixed top-0 end-0 p-3';
            toast.style.zIndex = '9999';
            toast.innerHTML = `
                <div class="toast show" role="alert">
                    <div class="toast-header bg-success text-white">
                        <i class="fas fa-check-circle me-2"></i>
                        <strong class="me-auto">Success</strong>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                    </div>
                    <div class="toast-body">
                        ${message}
                    </div>
                </div>
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.remove();
            }, 3000);
        }
    </script>
</body>

</html>