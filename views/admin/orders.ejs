    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="/mobile.js"></script>
    <script>
        const ordersData = <%- JSON.stringify(orders) %>;
        let filteredOrders = [...ordersData];

        // Filter state
        const filters = {
            search: '',
            payment: '',
            date: '',
            sort: 'date-desc'
        };

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function () {
            // Check for URL parameters (e.g., from Dashboard links)
            const urlParams = new URLSearchParams(window.location.search);
            const paymentParam = urlParams.get('payment');

            if (paymentParam && ['Cash', 'GPay', 'Pending'].includes(paymentParam)) {
                filters.payment = paymentParam;
                // Update UI visually
                setTimeout(() => {
                    document.querySelectorAll('.filter-btn[data-payment]').forEach(btn => btn.classList.remove('active'));
                    const activeBtn = document.querySelector(`.filter-btn[data-payment="${paymentParam}"]`);
                    if (activeBtn) activeBtn.classList.add('active');
                }, 50);
            }

            initializeFilters();
            updateFilterCounts();
            filterAndRenderOrders();
        });

        function initializeFilters() {
            // Search input
            const searchInput = document.getElementById('searchName');
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    filters.search = this.value.trim().toLowerCase();
                    updateSearchClearButton();
                    filterAndRenderOrders();
                });
            }

            // Sort dropdown
            const sortSelect = document.getElementById('sortBy');
            if (sortSelect) {
                sortSelect.addEventListener('change', function () {
                    filters.sort = this.value;
                    filterAndRenderOrders();
                });
            }

            // Payment filter buttons
            const paymentButtons = document.querySelectorAll('.filter-btn[data-payment]');
            paymentButtons.forEach(button => {
                button.addEventListener('click', function () {
                    // Remove active class from all payment buttons
                    document.querySelectorAll('.filter-btn[data-payment]').forEach(btn => {
                        btn.classList.remove('active');
                    });
                    // Add active class to clicked button
                    this.classList.add('active');
                    filters.payment = this.dataset.payment || '';
                    filterAndRenderOrders();
                });
            });

            // Date filter buttons
            const dateButtons = document.querySelectorAll('.filter-btn[data-date]');
            dateButtons.forEach(button => {
                button.addEventListener('click', function () {
                    // Remove active class from all date buttons
                    document.querySelectorAll('.filter-btn[data-date]').forEach(btn => {
                        btn.classList.remove('active');
                    });
                    // Add active class to clicked button
                    this.classList.add('active');
                    filters.date = this.dataset.date || '';
                    filterAndRenderOrders();
                });
            });

            // Clear filters button
            const clearFiltersBtn = document.getElementById('clearFiltersBtn');
            if (clearFiltersBtn) {
                clearFiltersBtn.addEventListener('click', clearAllFilters);
            }

            // Clear search button
            const searchClear = document.getElementById('searchClear');
            if (searchClear) {
                searchClear.addEventListener('click', clearSearch);
            }
        }

        function clearSearch() {
            const searchInput = document.getElementById('searchName');
            if (searchInput) {
                searchInput.value = '';
                filters.search = '';
                updateSearchClearButton();
                filterAndRenderOrders();
            }
        }

        function clearAllFilters() {
            // Clear search
            const searchInput = document.getElementById('searchName');
            if (searchInput) {
                searchInput.value = '';
                filters.search = '';
            }

            // Reset payment filter
            document.querySelectorAll('.filter-btn[data-payment]').forEach(btn => {
                btn.classList.remove('active');
            });
            const allPaymentBtn = document.querySelector('.filter-btn[data-payment=""]');
            if (allPaymentBtn) allPaymentBtn.classList.add('active');
            filters.payment = '';

            // Reset date filter
            document.querySelectorAll('.filter-btn[data-date]').forEach(btn => {
                btn.classList.remove('active');
            });
            const allDateBtn = document.querySelector('.filter-btn[data-date=""]');
            if (allDateBtn) allDateBtn.classList.add('active');
            filters.date = '';

            // Reset sort
            const sortSelect = document.getElementById('sortBy');
            if (sortSelect) {
                sortSelect.value = 'date-desc';
                filters.sort = 'date-desc';
            }

            updateSearchClearButton();
            filterAndRenderOrders();
        }

        function updateSearchClearButton() {
            const searchInput = document.getElementById('searchName');
            const clearButton = document.getElementById('searchClear');
            if (searchInput && clearButton) {
                clearButton.style.display = searchInput.value ? 'block' : 'none';
            }
        }

        function filterAndRenderOrders() {
            // Filter orders
            filteredOrders = ordersData.filter(order => {
                // Search filter
                if (filters.search) {
                    const customerName = (order.user?.name || '').toLowerCase();
                    const customerPhone = String(order.user?.phoneNumber || order.user?.number || '').toLowerCase();
                    const customerAddress = String(order.user?.address || '').toLowerCase();
                    const productSummary = (order.products || []).map(p => p.product?.name || '').join(' ').toLowerCase();

                    if (!customerName.includes(filters.search) &&
                        !customerPhone.includes(filters.search) &&
                        !customerAddress.includes(filters.search) &&
                        !productSummary.includes(filters.search)) {
                        return false;
                    }
                }

                // Payment filter
                if (filters.payment) {
                    const paymentMethod = order.paymentMethod || 'Cash';
                    if (paymentMethod !== filters.payment) {
                        return false;
                    }
                }

                // Date filter
                if (filters.date) {
                    const orderDate = new Date(order.orderDate);
                    if (isNaN(orderDate.getTime())) {
                        return false;
                    }

                    const now = new Date();
                    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

                    switch (filters.date) {
                        case 'today':
                            const orderDay = new Date(orderDate.getFullYear(), orderDate.getMonth(), orderDate.getDate());
                            if (orderDay.getTime() !== today.getTime()) return false;
                            break;
                        case 'week':
                            const weekAgo = new Date(today);
                            weekAgo.setDate(weekAgo.getDate() - 7);
                            if (orderDate < weekAgo) return false;
                            break;
                        case 'month':
                            const monthAgo = new Date(today);
                            monthAgo.setMonth(monthAgo.getMonth() - 1);
                            if (orderDate < monthAgo) return false;
                            break;
                        case 'year':
                            const yearAgo = new Date(today);
                            yearAgo.setFullYear(yearAgo.getFullYear() - 1);
                            if (orderDate < yearAgo) return false;
                            break;
                    }
                }

                return true;
            });

            // Sort orders
            switch (filters.sort) {
                case 'date-desc':
                    filteredOrders.sort((a, b) => new Date(b.orderDate) - new Date(a.orderDate));
                    break;
                case 'date-asc':
                    filteredOrders.sort((a, b) => new Date(a.orderDate) - new Date(b.orderDate));
                    break;
                case 'total-desc':
                    filteredOrders.sort((a, b) => b.total - a.total);
                    break;
                case 'total-asc':
                    filteredOrders.sort((a, b) => a.total - b.total);
                    break;
            }

            // Render the filtered orders
            renderOrders();
            updateFilterSummary();
        }

        function renderOrders() {
            const tbody = document.getElementById('ordersTableBody');
            if (!tbody) return;

            tbody.innerHTML = '';

            // Calculate totals
            let totalOrders = filteredOrders.length;
            let totalDiscount = 0;
            let totalPending = 0;
            let totalAmount = 0;

            if (filteredOrders.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="8">
                            <div class="table-empty">
                                <i class="fas fa-box-open"></i>
                                <h6 class="mb-2">No orders match these filters</h6>
                                <p class="mb-0">Try clearing filters or searching with a different term.</p>
                            </div>
                        </td>
                    </tr>
                `;
            } else {
                filteredOrders.forEach(order => {
                    totalDiscount += (order.discount || 0);
                    totalAmount += order.total;

                    const paymentMethod = order.paymentMethod || 'Cash';
                    if (paymentMethod === 'Pending') {
                        totalPending += order.total;
                    }
                    totalPending += (order.pending || 0);

                    const productsHtml = (order.products || []).map(item => {
                        const productName = item.product?.name || 'Unknown Product';
                        const quantity = Number(item.quantity) || 0;
                        return `<div><span class="badge bg-primary">${productName}</span> <strong>Qty: ${quantity}</strong></div>`;
                    }).join('');

                    const paymentBadge = paymentMethod === 'GPay' ? 'bg-success' :
                        paymentMethod === 'Pending' ? 'bg-warning text-dark' : 'bg-secondary';

                    const orderPending = (paymentMethod === 'Pending' ? order.total : 0) + (order.pending || 0);
                    const phone = order.user?.phoneNumber || order.user?.number || 'No phone';
                    const address = order.user?.address || 'No address';
                    const orderDate = new Date(order.orderDate);
                    const formattedDate = isNaN(orderDate.getTime()) ? 'Unknown date' : orderDate.toDateString();

                    tbody.innerHTML += `
                        <tr class="${orderPending > 0 ? 'table-warning' : ''}">
                            <td>
                                <strong>${order.user?.name || 'Unknown Customer'}</strong>
                                <span class="order-meta">${phone}</span>
                            </td>
                            <td>${productsHtml}</td>
                            <td>₹${(order.discount || 0).toFixed(2)}</td>
                            <td><span class="badge ${paymentBadge}">${paymentMethod}</span></td>
                            <td><strong style="color: #ef4444;">₹${orderPending.toFixed(2)}</strong></td>
                            <td><strong>₹${order.total.toFixed(2)}</strong></td>
                            <td>${formattedDate}<span class="order-meta">${address}</span></td>
                            <td>
                                <button class="btn btn-warning btn-sm edit-order-btn" 
                                    data-id="${order._id}" 
                                    data-name="${order.user?.name || ''}" 
                                    data-phone="${phone}" 
                                    data-address="${address}" 
                                    data-products='${JSON.stringify((order.products || []).map(p => ({
                        productId: p.product?._id,
                        quantity: p.quantity
                    })))}'
                                    data-discount="${order.discount || 0}" 
                                    data-payment="${paymentMethod}" 
                                    data-pending="${order.pending || 0}">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <form action="/admin/orders/delete/${order._id}" method="POST" style="display:inline;" onsubmit="return confirmDelete(this)">
                                    <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    `;
                });
            }

            // Update summary cards
            updateSummaryCards(totalOrders, totalDiscount, totalPending, totalAmount);
        }

        function updateSummaryCards(totalOrders, totalDiscount, totalPending, totalAmount) {
            const totalOrdersEl = document.getElementById('totalOrdersCount');
            const totalDiscountEl = document.getElementById('totalDiscountAmount');
            const totalPendingEl = document.getElementById('totalPendingAmount');
            const totalAmountEl = document.getElementById('totalAmountSum');

            if (totalOrdersEl) totalOrdersEl.textContent = totalOrders;
            if (totalDiscountEl) totalDiscountEl.textContent = `₹${totalDiscount.toFixed(2)}`;
            if (totalPendingEl) totalPendingEl.textContent = `₹${totalPending.toFixed(2)}`;
            if (totalAmountEl) totalAmountEl.textContent = `₹${totalAmount.toFixed(2)}`;
        }

        function updateFilterCounts() {
            // Count orders by payment method
            const paymentCounts = { 'Cash': 0, 'GPay': 0, 'Pending': 0 };

            // Count orders by date range
            const dateCounts = { 'today': 0, 'week': 0, 'month': 0, 'year': 0 };

            const now = new Date();
            const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            const weekAgo = new Date(today);
            weekAgo.setDate(weekAgo.getDate() - 7);
            const monthAgo = new Date(today);
            monthAgo.setMonth(monthAgo.getMonth() - 1);
            const yearAgo = new Date(today);
            yearAgo.setFullYear(yearAgo.getFullYear() - 1);

            ordersData.forEach(order => {
                const paymentMethod = order.paymentMethod || 'Cash';
                if (paymentCounts.hasOwnProperty(paymentMethod)) {
                    paymentCounts[paymentMethod]++;
                }

                const orderDate = new Date(order.orderDate);
                if (!isNaN(orderDate.getTime())) {
                    if (orderDate >= today) dateCounts.today++;
                    if (orderDate >= weekAgo) dateCounts.week++;
                    if (orderDate >= monthAgo) dateCounts.month++;
                    if (orderDate >= yearAgo) dateCounts.year++;
                }
            });

            // Update badges
            updateBadge('allPaymentCount', ordersData.length);
            updateBadge('cashCount', paymentCounts['Cash']);
            updateBadge('gpayCount', paymentCounts['GPay']);
            updateBadge('pendingCount', paymentCounts['Pending']);
            updateBadge('allDateCount', ordersData.length);
            updateBadge('todayCount', dateCounts.today);
            updateBadge('weekCount', dateCounts.week);
            updateBadge('monthCount', dateCounts.month);
            updateBadge('yearCount', dateCounts.year);
        }

        function updateBadge(badgeId, count) {
            const badge = document.getElementById(badgeId);
            if (badge) {
                if (count > 0) {
                    badge.textContent = count;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            }
        }

        function updateFilterSummary() {
            const activeFiltersCount = [
                filters.search,
                filters.payment,
                filters.date
            ].filter(f => f !== '').length;

            const visibleCount = filteredOrders.length;
            const totalCount = ordersData.length;

            // Update counts
            const activeFiltersEl = document.getElementById('activeFiltersCount');
            const resultsCountEl = document.getElementById('resultsCount');

            if (activeFiltersEl) {
                activeFiltersEl.textContent = `${activeFiltersCount} active`;
                activeFiltersEl.className = activeFiltersCount > 0 ? 'filter-count active' : 'filter-count';
            }
            if (resultsCountEl) {
                resultsCountEl.textContent = `${visibleCount} results`;
            }

            // Show/hide summary
            const summary = document.getElementById('filterSummary');
            const visibleCountEl = document.getElementById('visibleCount');
            const filterDescription = document.getElementById('filterDescription');

            if (summary && visibleCountEl && filterDescription) {
                if (activeFiltersCount > 0 || visibleCount < totalCount) {
                    summary.style.display = 'block';
                    visibleCountEl.textContent = visibleCount;

                    // Build filter description
                    let description = '';
                    if (filters.search) description += ` matching "${filters.search}"`;
                    if (filters.payment) description += ` with ${filters.payment} payment`;
                    if (filters.date) description += ` from ${filters.date}`;

                    filterDescription.textContent = description;
                } else {
                    summary.style.display = 'none';
                }
            }
        }

