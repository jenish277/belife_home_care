                            <div class="row g-2">
                                <div class="col-9">
                                    <select name="productId" class="form-select product-select" required>
                                        <option value="">Select Product</option>
                                        <% products.forEach(product => { %>
                                        <option value="<%= product._id %>" data-price="<%= product.price %>"><%= product.name %> - ₹<%= product.price %> (Stock: <%= product.availableQuantity %>)</option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-2">
                                    <input type="number" name="quantity" class="form-control quantity-input px-1 text-center" placeholder="Qty" min="1" required>
                                </div>
                                <div class="col-1 d-flex align-items-center">
                                    <button type="button" class="btn btn-outline-danger remove-product w-100" style="display:${products.length > 1 ? 'block' : 'none'}; height:38px; padding:0;"><i class="fas fa-times"></i></button>
                                </div>
                            </div>
                        `;
                        productsList.appendChild(productRow);

                        // Set values
                        const productSelect = productRow.querySelector('.product-select');
                        const quantityInput = productRow.querySelector('.quantity-input');
                        if (productSelect) productSelect.value = product.productId || '';
                        if (quantityInput) quantityInput.value = product.quantity || 1;

