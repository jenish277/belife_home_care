        <div class="card table-card">
            <div class="table-toolbar">
                <div>
                    <h5>Orders List</h5>
                    <p>Live filters update the metrics and table together.</p>
                </div>
                <div class="search-box-modern" style="min-width: 300px; max-width: 450px; flex: 1;">
                    <div class="search-input-wrapper">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" id="searchName" class="form-control search-input"
                            placeholder="Search by customer, phone, address or product...">
                        <button class="search-clear-btn" id="searchClear" style="display: none;">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
